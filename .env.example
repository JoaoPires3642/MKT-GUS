# ===========================================
# MKT-GUS Environment Configuration
# ===========================================
# Copy this file to .env and update the values as needed
# cp .env.example .env

# ===========================================
# Database Configuration
# ===========================================
# For local development: use docker-compose.local.yml
# For production: use docker-compose.prod.yml

# PostgreSQL (Local/Production)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_password_here
POSTGRES_DB=postgres
POSTGRES_PORT=5432

# Supabase (Production) - Use these for production deployment
SPRING_DATASOURCE_URL=jdbc:postgresql://db.xxxxx.supabase.co:5432/postgres
SPRING_DATASOURCE_USERNAME=postgres
SPRING_DATASOURCE_PASSWORD=your_password_here
SPRING_DATASOURCE_DRIVER_CLASS_NAME=org.postgresql.Driver
SPRING_DATASOURCE_HIKARI_SCHEMA=public

# JPA/Hibernate
SPRING_JPA_HIBERNATE_DDL_AUTO=update

# ===========================================
# Backend Configuration
# ===========================================
BACKEND_PORT=8080
SPRING_PROFILES_ACTIVE=prod

# Points System
PONTOS_VALOR_POR_PONTO=5.0
PONTOS_PONTOS_POR_BLOCO=10

# ===========================================
# Frontend Configuration
# ===========================================
FRONTEND_PORT=3000
NEXT_PUBLIC_API_URL=http://localhost:8080
NEXT_PUBLIC_WS_URL=ws://localhost:8080/ws

# ===========================================
# Application Settings
# ===========================================
LOG_LEVEL=INFO
TZ=America/Sao_Paulo

# ===========================================
# Security (Change in production!)
# ===========================================
JWT_SECRET=your-jwt-secret-here
API_KEY=your-api-key-here